// ── Minimap ───────────────────────────────────────────────
function drawMinimap(){
  const cw=MM.width/MC,ch=MM.height/MR;
  mmc.fillStyle='rgba(0,0,0,0.8)';mmc.fillRect(0,0,MM.width,MM.height);
  for(let r=0;r<MR;r++)for(let c=0;c<MC;c++){
    const t=MAP[r][c];
    if(!t)continue;
    mmc.fillStyle=t===1?'#5a4a38':t===2?'#3a4a5a':'#4a3a28';
    mmc.fillRect(c*cw,r*ch,cw,ch);
  }
  // Drops
  for(const d of drops){
    if(!d.alive)continue;
    mmc.fillStyle='#39ff14';
    mmc.beginPath();mmc.arc(d.x/CS*cw,d.y/CS*ch,2,0,TAU);mmc.fill();
  }
  // Zombies
  for(const z of zombies){
    if(!z.alive)continue;
    mmc.fillStyle=z.state==='chase'?'#ff2200':'#aa2200';
    mmc.beginPath();mmc.arc(z.x/CS*cw,z.y/CS*ch,1.8,0,TAU);mmc.fill();
  }
  // Player
  const px=PL.x/CS*cw,py=PL.y/CS*ch;
  mmc.fillStyle='#39ff14';mmc.beginPath();mmc.arc(px,py,3.5,0,TAU);mmc.fill();
  mmc.strokeStyle='#39ff14';mmc.lineWidth=1.5;
  mmc.beginPath();mmc.moveTo(px,py);mmc.lineTo(px+Math.cos(PL.ang)*9,py+Math.sin(PL.ang)*9);mmc.stroke();
}

// ── Shoot ─────────────────────────────────────────────────
function shoot(){
  if(G.st!=='playing'||PL.dead)return;
  if(PL.rld||PL.stimer>0)return;
  const w=WEAPONS[PL.gun];
  if(PL.ammo<=0){SFX.dryfire();if(PL.res>0)startReload();return}

  PL.ammo--;PL.stimer=Math.round(3600/w.rpm)|0;PL.recoil=1.2;PL.sf++;
  SFX[w.sfx]();

  // Muzzle flash screen tint
  const dv=document.getElementById('dmgv');
  dv.style.background='rgba(255,200,80,0.04)';dv.style.opacity='1';
  setTimeout(()=>{dv.style.background='radial-gradient(ellipse,transparent 35%,rgba(150,0,0,.9) 100%)';dv.style.opacity='0'},45);

  const xh=document.getElementById('xh');xh.classList.remove('hit');
  const pells=w.pell||1;let gotHit=false;

  for(let p=0;p<pells;p++){
    const ang=PL.ang+(Math.random()-0.5)*w.sprd*2;
    for(const z of zombies){
      if(!z.alive)continue;
      const dx=z.x-PL.x,dy=z.y-PL.y,pd=dist(0,0,dx,dy);
      const za=Math.atan2(dy,dx);
      const diff=angleDiff(za,ang);
      const hitR=Math.atan2(z.sz+4,Math.max(pd,1));
      if(Math.abs(diff)>hitR)continue;
      const{d:wd}=castRay(ang);
      if(wd<pd-8)continue;
      const fo=Math.max(0.2,1-pd/(CS*18));
      const dmg=Math.round(w.dmg*fo*(0.8+Math.random()*0.4));
      z.hp-=dmg;z.hitFlash=8;PL.sh++;G.score+=3;gotHit=true;
      // blood particles
      for(let i=0;i<9;i++)parts.push({
        x:z.x,y:z.y,
        vx:(Math.random()-0.5)*1.4,vy:(Math.random()-0.5)*1.4,
        life:25+Math.random()*20,ml:45,
        col:`rgb(${100+Math.floor(Math.random()*80)},0,0)`
      });
      if(z.hp<=0)killZombie(z);
      break;
    }
  }

  if(gotHit){
    xh.classList.add('hit');
    const hm=document.getElementById('hitmark');hm.classList.remove('pop');void hm.offsetWidth;hm.classList.add('pop');
    SFX.hit();
  }
  updAmmo();
}

function killZombie(z){
  z.alive=false;G.kills++;G.tk++;G.score+=z.sc;G.coins+=z.coins;
  SFX.zombieDie();
  addKF(`✕ ${z.type.toUpperCase()} DOWN`,'red');
  for(let i=0;i<20;i++)parts.push({
    x:z.x,y:z.y,
    vx:(Math.random()-0.5)*2,vy:(Math.random()-0.5)*2,
    life:38+Math.random()*30,ml:68,
    col:`rgb(${80+Math.floor(Math.random()*90)},0,0)`
  });
  // 5% ammo drop
  if(Math.random()<0.05){
    const w=WEAPONS[PL.gun];
    const amt=Math.round(w.mag*0.5+4);
    drops.push({x:z.x,y:z.y,amt,alive:true,bobT:Math.random()*TAU});
    addKF(`⊕ AMMO DROP`,'green');
  }
  updTop();
}

// ── Reload ────────────────────────────────────────────────
function startReload(){
  const w=WEAPONS[PL.gun];
  if(PL.rld||PL.res<=0||PL.ammo>=w.mag)return;
  PL.rld=true;PL.rldp=0;PL.rldd=w.rld;
  SFX.reload();
  document.getElementById('rldwrap').style.display='block';
}
function tickReload(dt){
  if(!PL.rld)return;
  PL.rldp+=dt;
  document.getElementById('rldfill').style.width=clamp(PL.rldp/PL.rldd,0,1)*100+'%';
  if(PL.rldp>=PL.rldd){
    const w=WEAPONS[PL.gun];
    const need=w.mag-PL.ammo,take=Math.min(need,PL.res);
    PL.ammo+=take;PL.res-=take;
    PL.rld=false;
    document.getElementById('rldwrap').style.display='none';
    updAmmo();
  }
}

// ── Player update ─────────────────────────────────────────
const SENS=0.0023,PLIM=255;
function updPlayer(dt){
  if(PL.dead)return;

  // Mouse look
  PL.ang+=mdx*SENS;
  PL.pitch=clamp(PL.pitch-mdy*SENS*C.height*0.54,-PLIM,PLIM);
  mdx=0;mdy=0;

  // WASD
  const spr=K['ShiftLeft']||K['ShiftRight'];
  const spd=(spr?5.5:3.3)*dt*60;
  let dx=0,dy=0;
  if(K['KeyW']||K['ArrowUp'])    {dx+=Math.cos(PL.ang)*spd;dy+=Math.sin(PL.ang)*spd}
  if(K['KeyS']||K['ArrowDown'])  {dx-=Math.cos(PL.ang)*spd;dy-=Math.sin(PL.ang)*spd}
  if(K['KeyA']||K['ArrowLeft'])  {const a=PL.ang-HALF_PI;dx+=Math.cos(a)*spd;dy+=Math.sin(a)*spd}
  if(K['KeyD']||K['ArrowRight']) {const a=PL.ang+HALF_PI;dx+=Math.cos(a)*spd;dy+=Math.sin(a)*spd}
  if(K['Space']&&!WEAPONS[PL.gun].auto)shoot();

  if(dx||dy){
    const r=slideMove(PL.x,PL.y,dx,dy,13);PL.x=r.x;PL.y=r.y;
    PL.bobt+=spr?0.18:0.1;
    PL.bob=Math.sin(PL.bobt)*4*(spr?1.65:1);
  } else {PL.bob*=0.83;PL.bobt*=0.88}

  if(PL.stimer>0)PL.stimer--;
  PL.recoil=Math.max(0,PL.recoil-0.075);

  if(mdown&&WEAPONS[PL.gun].auto)shoot();
  tickReload(dt);

  // Pickup drops
  for(const d of drops){
    if(!d.alive)continue;
    if(dist(PL.x,PL.y,d.x,d.y)<CS*0.6){
      d.alive=false;
      const w=WEAPONS[PL.gun];
      PL.res=Math.min(w.res*3,PL.res+d.amt);
      SFX.pickup();
      const pf=document.getElementById('pickupflash');
      pf.textContent=`+${d.amt} AMMO`;
      pf.classList.remove('show');void pf.offsetWidth;pf.classList.add('show');
      updAmmo();
    }
  }
}

// ── Wave system (endless) ─────────────────────────────────
const waveCount=w=>Math.round(6+w*3.2+Math.floor(w/3));

function startWave(w){
  G.wave=w;G.kills=0;
  zombies=[];parts=[];drops=[];
  spawnQ=waveCount(w);spawnT=0;G.wactive=true;

  // Map rotation every 4 waves (looping)
  setMap(Math.floor((w-1)/4));

  // Partial ammo refill each wave
  const wd=WEAPONS[PL.gun];
  PL.res=Math.min(wd.res*3,PL.res+Math.round(wd.res*0.55));
  if(PL.ammo===0){const tk=Math.min(wd.mag,PL.res);PL.ammo+=tk;PL.res-=tk}

  // Reposition player to safe center cell
  PL.x=2.5*CS;PL.y=2.5*CS;

  updTop();updAmmo();updHP();SFX.waveStart();

  const wb=document.getElementById('wbanner');
  document.getElementById('wbtitle').textContent=`WAVE ${w}`;
  document.getElementById('wbsub').textContent=`${waveCount(w)} ZOMBIES`;
  document.getElementById('wbloc').textContent=MAP_NAMES[activeMap];
  wb.classList.remove('show');void wb.offsetWidth;wb.classList.add('show');
}

function checkWaveEnd(){
  if(!G.wactive)return;
  if(spawnQ<=0&&zombies.filter(z=>z.alive).length===0){
    G.wactive=false;
    SFX.levelUp();
    setTimeout(openShop,1300);
  }
}

// ── Shop ──────────────────────────────────────────────────
let shopIv=null,shopTimer=0;
function openShop(){
  G.st='shop';document.exitPointerLock();
  document.getElementById('sshop').classList.remove('off');
  document.getElementById('hud').classList.add('off');
  shopTimer=15;
  document.getElementById('shopbar').style.width='100%';
  document.getElementById('shopcval').textContent=G.coins;
  buildShop();
  if(shopIv)clearInterval(shopIv);
  shopIv=setInterval(()=>{
    shopTimer-=0.1;
    const p=clamp(shopTimer/15,0,1);
    document.getElementById('shopbar').style.width=(p*100)+'%';
    document.getElementById('shopsec').textContent=Math.ceil(shopTimer)+'s';
    if(shopTimer<=0){clearInterval(shopIv);shopIv=null;closeShop()}
  },100);
}

function buildShop(){
  const g=document.getElementById('shopgrid');g.innerHTML='';
  for(const item of CATALOG){
    const isW=!!item.wep,isC=!!item.con;
    const owned=G.owned.has(item.id)||G.upg.has(item.id);
    const eqpd=PL.gun===item.id;
    const afford=G.coins>=item.price;
    const el=document.createElement('div');
    el.className='sitem'+(owned&&!isC?' owned':'')+(eqpd?' equipped':'')+((!afford&&!owned&&!isC)||(!afford&&isC)?' cant':'');
    let bot='';
    if(isC)bot=afford?`<div class="iprice">⬡ ${item.price}</div>`:`<div class="iprice" style="opacity:.35">⬡ ${item.price}</div>`;
    else if(owned)bot=eqpd?`<div class="iequip">✓ EQUIPPED</div>`:`<div class="iowned">✓ OWN — EQUIP</div>`;
    else bot=afford?`<div class="iprice">⬡ ${item.price}</div>`:`<div class="iprice" style="opacity:.35">⬡ ${item.price}</div>`;
    el.innerHTML=`<div class="iname">${item.label}</div><div class="idesc">${item.desc}</div><div class="istats">${item.stats}</div>${bot}`;
    el.addEventListener('click',()=>buyItem(item));
    g.appendChild(el);
  }
}

function buyItem(item){
  const isW=!!item.wep,isC=!!item.con;
  if(isC){
    if(G.coins<item.price)return;
    G.coins-=item.price;applyUpg(item.id);SFX.buy();
    document.getElementById('shopcval').textContent=G.coins;buildShop();return;
  }
  if(isW){
    if(G.owned.has(item.id)){equipGun(item.id);buildShop();return}
    if(G.coins<item.price)return;
    G.coins-=item.price;G.owned.add(item.id);equipGun(item.id);SFX.buy();
    document.getElementById('shopcval').textContent=G.coins;buildShop();return;
  }
  // perm upgrade
  if(G.upg.has(item.id)||G.coins<item.price)return;
  G.coins-=item.price;G.upg.add(item.id);applyUpg(item.id);SFX.buy();
  document.getElementById('shopcval').textContent=G.coins;buildShop();
}

function equipGun(id){
  const w=WEAPONS[id];PL.gun=id;PL.ammo=w.mag;PL.res=w.res;PL.rld=false;
  document.getElementById('wname').textContent=w.name;updAmmo();
}

function applyUpg(id){
  if(id==='hp25')PL.hp=clamp(PL.hp+25,0,PL.mhp);
  else if(id==='hpmax')PL.hp=PL.mhp;
  else if(id==='ammopack')PL.res=Math.round(WEAPONS[PL.gun].res*1.5);
  else if(id==='armor'){PL.mhp+=50;PL.hp=clamp(PL.hp+50,0,PL.mhp)}
  updHP();
}

function closeShop(){
  if(shopIv){clearInterval(shopIv);shopIv=null}
  document.getElementById('sshop').classList.add('off');
  document.getElementById('hud').classList.remove('off');
  G.st='playing';C.requestPointerLock();
  startWave(G.wave+1);
}

// ── HUD helpers ───────────────────────────────────────────
function showDmgFlash(){
  const d=document.getElementById('dmgv');
  d.style.background='radial-gradient(ellipse,transparent 35%,rgba(150,0,0,.9) 100%)';
  d.style.opacity='0.8';setTimeout(()=>d.style.opacity='0',120);
}
function addKF(msg,cls='red'){
  const kf=document.getElementById('kfeed');
  const el=document.createElement('div');el.className='krow '+cls;el.textContent=msg;
  kf.prepend(el);setTimeout(()=>el.remove(),3100);
  while(kf.children.length>5)kf.lastChild.remove();
}
function updTop(){
  document.getElementById('hudwave').textContent=G.wave;
  document.getElementById('hudkills').textContent=G.kills;
  document.getElementById('hudscore').textContent=G.score;
  document.getElementById('hudcoins').textContent=G.coins;
}
function updHP(){
  const p=PL.hp/PL.mhp;
  document.getElementById('hpf').style.width=clamp(p,0,1)*100+'%';
  document.getElementById('hpf').style.background=
    p>0.5?'linear-gradient(90deg,#8b0000,#dd2200)':
    p>0.25?'linear-gradient(90deg,#994400,#cc6600)':
           'linear-gradient(90deg,#660000,#ff3300)';
  document.getElementById('hpn').textContent=`${Math.max(0,PL.hp)} / ${PL.mhp}`;
  document.body.classList.toggle('lhp',p<0.3);
}
function updAmmo(){
  document.getElementById('amcur').textContent=PL.ammo;
  document.getElementById('ammax').textContent=WEAPONS[PL.gun].mag;
  document.getElementById('amresval').textContent=PL.res;
  document.getElementById('wname').textContent=WEAPONS[PL.gun].name;
}

// ── Screens ───────────────────────────────────────────────
function showSc(id){
  ['st','show','spause','sshop','sover'].forEach(s=>document.getElementById(s).classList.toggle('off',s!==id));
}

function startGame(){
  initAC();
  Object.assign(PL,{x:2.5*CS,y:2.5*CS,ang:0,pitch:0,hp:100,mhp:100,
    gun:'pistol',ammo:12,res:48,rld:false,rldp:0,stimer:0,recoil:0,
    bob:0,bobt:0,sf:0,sh:0,dtaken:0,dead:false});
  Object.assign(G,{wave:1,score:0,kills:0,tk:0,coins:0,
    owned:new Set(['pistol']),upg:new Set(),wactive:false});
  zombies=[];drops=[];parts=[];
  setMap(0);
  document.body.classList.remove('lhp');
  showSc(null);
  document.getElementById('hud').classList.remove('off');
  document.getElementById('wname').textContent='PISTOL';
  G.st='playing';
  C.requestPointerLock();
  startWave(1);
  updTop();updAmmo();updHP();
}

function doPause(){
  G.st='paused';document.exitPointerLock();
  document.getElementById('spause').classList.remove('off');
}
function doResume(){
  G.st='playing';
  document.getElementById('spause').classList.add('off');
  C.requestPointerLock();
}
function doGameOver(){
  PL.dead=true;G.st='gameover';document.exitPointerLock();
  document.body.classList.remove('lhp');
  const acc=PL.sf?Math.round(PL.sh/PL.sf*100):0;
  document.getElementById('overstats').innerHTML=`
    <div class="srow"><span class="slbl">Wave Reached</span><span class="sval">${G.wave}</span></div>
    <div class="srow"><span class="slbl">Total Kills</span><span class="sval">${G.tk}</span></div>
    <div class="srow"><span class="slbl">Final Score</span><span class="sval">${G.score}</span></div>
    <div class="srow"><span class="slbl">Coins Earned</span><span class="sval">${G.coins}</span></div>
    <div class="srow"><span class="slbl">Accuracy</span><span class="sval">${acc}%</span></div>
    <div class="srow"><span class="slbl">Damage Taken</span><span class="sval">${PL.dtaken}</span></div>`;
  document.getElementById('sover').classList.remove('off');
  document.getElementById('hud').classList.add('off');
}

// ── Buttons ───────────────────────────────────────────────
document.getElementById('b_start').onclick=startGame;
document.getElementById('b_how').onclick=()=>{SFX.menuClick&&initAC();showSc('show')};
document.getElementById('b_backhow').onclick=()=>showSc('st');
document.getElementById('b_resume').onclick=doResume;
document.getElementById('b_quitmenu').onclick=()=>{G.st='title';document.exitPointerLock();document.getElementById('hud').classList.add('off');document.body.classList.remove('lhp');showSc('st')};
document.getElementById('b_skip').onclick=closeShop;
document.getElementById('b_retry').onclick=startGame;
document.getElementById('b_quitover').onclick=()=>showSc('st');
C.addEventListener('click',()=>{if(G.st==='playing'&&document.pointerLockElement!==C)C.requestPointerLock()});

// ── FPS ───────────────────────────────────────────────────
let lastT=performance.now(),fpsF=0,fpsL=0;
function tickFPS(now){
  fpsF++;
  if(now-fpsL>600){
    document.getElementById('fpsc').textContent=Math.round(fpsF/((now-fpsL)/1000))+' FPS';
    fpsL=now;fpsF=0;
  }
}

// ── Main loop ─────────────────────────────────────────────
function loop(now){
  requestAnimationFrame(loop);
  const dt=Math.min((now-lastT)/1000,0.05);lastT=now;
  tickFPS(now);
  if(G.st==='playing'){
    spawnT++;
    if(spawnQ>0&&spawnT>=SPAWNGAP){spawnT=0;spawnQ--;spawnZombie()}
    updPlayer(dt);
    updateZombies(dt);
    checkWaveEnd();
    updTop();
    render();
    drawMinimap();
  } else if(G.st==='paused'){
    render();drawMinimap();
  }
}

showSc('st');
requestAnimationFrame(loop);
</script>
</body>
</html>
