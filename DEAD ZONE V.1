// Improved slide-move: tries both axes independently, also nudges around corners
function slideMove(x,y,dx,dy,r){
  r=r||13;
  let nx=x,ny=y;
  const eps=0.5;
  // try X
  const tx=x+dx;
  if(!solid(tx,y-r+eps)&&!solid(tx,y+r-eps)&&!solid(tx-r+eps,y)&&!solid(tx+r-eps,y)) nx=tx;
  // try Y
  const ty=y+dy;
  if(!solid(nx,ty-r+eps)&&!solid(nx,ty+r-eps)&&!solid(nx-r+eps,ty)&&!solid(nx+r-eps,ty)) ny=ty;
  return{x:nx,y:ny};
}

// ── Raycaster ─────────────────────────────────────────────
const NRAYS=480, FOV=PI/2.4, HFOV=FOV/2, MAXD=CS*26;
const ZB=new Float32Array(NRAYS);

function castRay(ang){
  const cos=Math.cos(ang)||1e-10, sin=Math.sin(ang)||1e-10;
  let mx=PL.x/CS|0, my=PL.y/CS|0;
  const ddx=Math.abs(CS/cos), ddy=Math.abs(CS/sin);
  const sx=cos>0?1:-1, sy=sin>0?1:-1;
  let sdx=cos>0?(mx+1-PL.x/CS)*ddx:(PL.x/CS-mx)*ddx;
  let sdy=sin>0?(my+1-PL.y/CS)*ddy:(PL.y/CS-my)*ddy;
  let side=0,wt=1,wallX=0;
  for(let i=0;i<96;i++){
    if(sdx<sdy){sdx+=ddx;mx+=sx;side=0}
    else{sdy+=ddy;my+=sy;side=1}
    if(mx<0||mx>=MC||my<0||my>=MR)return{d:MAXD,side,wt:1,wx:0};
    wt=MAP[my][mx];
    if(wt){
      const d=side===0?(mx-PL.x/CS+(sx<0?1:0))/cos*CS:(my-PL.y/CS+(sy<0?1:0))/sin*CS;
      // wall texture coordinate
      wallX=side===0?PL.y+Math.sin(ang)*d:PL.x+Math.cos(ang)*d;
      wallX=(wallX/CS)%1;
      if(wallX<0)wallX+=1;
      return{d:Math.max(1,d),side,wt,wx:wallX};
    }
  }
  return{d:MAXD,side:0,wt:1,wx:0};
}

