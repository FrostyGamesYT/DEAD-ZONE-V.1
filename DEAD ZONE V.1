const ZTYPES={
  walker:{hp:55, spd:.7, dmg:10,sc:10,coins:4, sz:13,color:'#5c3010'},
  runner:{hp:35, spd:1.5,dmg:7, sc:15,coins:5, sz:10,color:'#3c1010'},
  brute: {hp:200,spd:.42,dmg:28,sc:40,coins:14,sz:22,color:'#2c1a04'},
  scream:{hp:65, spd:1.1,dmg:13,sc:25,coins:7, sz:13,color:'#1c0030'},
  tank:  {hp:380,spd:.28,dmg:38,sc:75,coins:25,sz:28,color:'#080808'},
};

function pickZType(wave){
  const pool=[
    ['walker',Math.max(0,7-wave)],
    ['runner',wave>=2?4:0],
    ['brute', wave>=4?2:0],
    ['scream',wave>=5?3:0],
    ['tank',  wave>=8?1:0],
  ].filter(x=>x[1]>0);
  let tot=pool.reduce((a,b)=>a+b[1],0),r=Math.random()*tot;
  for(const[t,w]of pool){r-=w;if(r<=0)return t}
  return'walker';
}

// Find a valid open spawn point away from player
function findSpawnPoint(){
  for(let attempt=0;attempt<400;attempt++){
    const mx=1+Math.floor(Math.random()*(MC-2));
    const my=1+Math.floor(Math.random()*(MR-2));
    if(MAP[my][mx]!==0)continue;
    const wx=mx*CS+CS*0.5, wy=my*CS+CS*0.5;
    if(dist(wx,wy,PL.x,PL.y)<CS*5)continue;
    // make sure not stuck in a 1-cell pocket
    const free=(!solid(wx+CS,wy))||(!solid(wx-CS,wy))||(!solid(wx,wy+CS))||(!solid(wx,wy-CS));
    if(free)return{x:wx,y:wy};
  }
  return null;
}

function spawnZombie(){
  const sp=findSpawnPoint();if(!sp)return;
  const type=pickZType(G.wave),t=ZTYPES[type];
  const scale=1+(G.wave-1)*0.14;
  zombies.push({
    x:sp.x,y:sp.y,
    ang:Math.random()*TAU,
    targetAng:Math.random()*TAU,
    hp:Math.round(t.hp*scale), mhp:Math.round(t.hp*scale),
    spd:t.spd*(1+(G.wave-1)*0.045),
    dmg:Math.round(t.dmg*(1+(G.wave-1)*0.07)),
    sc:t.sc, coins:t.coins,
    sz:t.sz, type, alive:true,
    state:'wander',
    stuckT:0,lastX:sp.x,lastY:sp.y,
    wanderT:60+Math.random()*80,
    atkT:0,atkCD:85,
    growlT:100+Math.floor(Math.random()*200),
    hitFlash:0, bobT:Math.random()*TAU,
    id:Math.random(),
  });
}

// ── Zombie AI (unstuck logic) ──────────────────────────────
function updateZombies(dt){
  for(const z of zombies){
    if(!z.alive)continue;
    const dx=PL.x-z.x,dy=PL.y-z.y,pd=dist(PL.x,PL.y,z.x,z.y);

    // Growl
    z.growlT--;
    if(z.growlT<=0&&pd<CS*10){SFX.zombieGrowl();z.growlT=150+Math.random()*200}

    // State transitions
    if(pd<CS*12)z.state='chase';
    else if(pd>CS*16)z.state='wander';

    z.bobT+=dt*6;
    const step=z.spd*dt*60;

    if(z.state==='wander'){
      z.wanderT-=dt*60;
      if(z.wanderT<=0){
        z.targetAng=Math.random()*TAU;
        z.wanderT=60+Math.random()*80;
      }
      // Smooth turn toward target angle
      const da=angleDiff(z.targetAng,z.ang);
      z.ang+=clamp(da,-0.1,-0.1/da*Math.abs(da))*Math.min(1,Math.abs(da));// smooth
      z.ang+=clamp(da,-0.1,0.1);
      const mv=slideMove(z.x,z.y,Math.cos(z.ang)*step*0.5,Math.sin(z.ang)*step*0.5,z.sz);
      // If blocked, pick new angle
      if(mv.x===z.x&&mv.y===z.y){z.targetAng=Math.random()*TAU;z.wanderT=30}
      z.x=mv.x;z.y=mv.y;
    } else {
      // Chase: steer toward player
      const desiredAng=Math.atan2(dy,dx);
      const da=angleDiff(desiredAng,z.ang);
      z.ang+=clamp(da,-0.14,0.14);

      if(pd>z.sz+16){
        const mv=slideMove(z.x,z.y,Math.cos(z.ang)*step,Math.sin(z.ang)*step,z.sz);

        // Stuck detection: if barely moved over 30 frames, try a random detour
        z.stuckT++;
        if(z.stuckT>30){
          const moved=dist(z.x,z.y,z.lastX,z.lastY);
          if(moved<2){
            // Steer 90° randomly to get around obstacle
            z.ang+=HALF_PI*(Math.random()<0.5?1:-1);
          }
          z.stuckT=0;z.lastX=z.x;z.lastY=z.y;
        }
        z.x=mv.x;z.y=mv.y;
      }

      // Attack
      if(pd<z.sz+22){
        z.atkT+=dt*60;
        if(z.atkT>=z.atkCD){
          z.atkT=0;
          PL.hp-=z.dmg;PL.dtaken+=z.dmg;
          SFX.playerHurt();showDmgFlash();
          updHP();
          if(PL.hp<=0){PL.hp=0;doGameOver()}
        }
      } else z.atkT=0;
    }

    // Zombie-zombie separation
    for(const z2 of zombies){
      if(z2===z||!z2.alive)continue;
      const sdx=z.x-z2.x,sdy=z.y-z2.y,sd=dist(0,0,sdx,sdy);
      if(sd<z.sz+z2.sz+1&&sd>0.01){const f=(z.sz+z2.sz+1-sd)/sd*0.4;z.x+=sdx*f;z.y+=sdy*f}
    }

    if(z.hitFlash>0)z.hitFlash--;
  }
}

// ── Render ────────────────────────────────────────────────
function render(){
  const W=C.width,H=C.height,HH=H*0.5+PL.pitch;
  const slW=Math.ceil(W/NRAYS)+1, rs=FOV/NRAYS;

  // Sky gradient
  const sg=ctx.createLinearGradient(0,0,0,HH);
  sg.addColorStop(0,ENV.sky0);sg.addColorStop(1,ENV.sky1);
  ctx.fillStyle=sg;ctx.fillRect(0,0,W,Math.max(0,HH));

  // Floor gradient with distance darkening
  const fg=ctx.createLinearGradient(0,HH,0,H);
  fg.addColorStop(0,ENV.floor0);fg.addColorStop(1,ENV.floor1);
  ctx.fillStyle=fg;ctx.fillRect(0,Math.max(0,HH),W,H);

  // Walls
  for(let i=0;i<NRAYS;i++){
    const ang=(PL.ang-HFOV)+i*rs;
    const{d:raw,side,wt,wx}=castRay(ang);
    const d=raw*Math.cos(ang-PL.ang); // fisheye correction
    ZB[i]=d;

    const wh=Math.min(H*4,(H*CS*0.9)/Math.max(d,1));
    const wTop=HH-wh*0.5, wBot=HH+wh*0.5;
    const sx=(i/NRAYS)*W;
    const fog=clamp(d/MAXD,0,1);

    const pal=PAL[wt]||PAL[1];
    let baseCol=side===0?pal[0]:pal[1];

    // Texture: alternating stripe pattern using wallX
    const stripe=Math.floor(wx*8)%2===0;
    if(stripe){
      // slightly lighter stripe
      const r=parseInt(baseCol.slice(1,3),16),g=parseInt(baseCol.slice(3,5),16),b=parseInt(baseCol.slice(5,7),16);
      baseCol=`rgb(${Math.min(r+12,255)},${Math.min(g+10,255)},${Math.min(b+8,255)})`;
    }

    // Directional lighting: N/S walls slightly brighter
    ctx.fillStyle=baseCol;
    ctx.globalAlpha=clamp((1-fog*0.55)*(side===0?1:0.78),0.1,1);
    ctx.fillRect(sx,wTop,slW,wh);

    // Fog layer
    if(fog>0.04){
      ctx.fillStyle=`rgba(8,4,2,${fog*0.48})`;
      ctx.globalAlpha=1;
      ctx.fillRect(sx,wTop,slW,wh);
    }

    // Floor contact shadow
    ctx.fillStyle='rgba(0,0,0,0.22)';
    ctx.fillRect(sx,wBot-wh*0.12,slW,wh*0.12);

    // Ceiling darkening
    ctx.fillStyle='rgba(0,0,0,0.16)';
    ctx.fillRect(sx,wTop,slW,wh*0.08);

    ctx.globalAlpha=1;
  }

  drawZombies(W,H,HH);
  drawDrops(W,H,HH);
  drawParticles(W,H,HH);
  drawWeapon(W,H);

  // Vignette
  const vg=ctx.createRadialGradient(W*0.5,H*0.5,H*0.3,W*0.5,H*0.5,H*0.82);
  vg.addColorStop(0,'rgba(0,0,0,0)');vg.addColorStop(1,'rgba(0,0,0,0.4)');
  ctx.fillStyle=vg;ctx.fillRect(0,0,W,H);
}

// ── Zombie renderer (improved visuals) ───────────────────
function drawZombies(W,H,HH){
  const alive=zombies.filter(z=>z.alive);
  alive.sort((a,b)=>dist(PL.x,PL.y,b.x,b.y)-dist(PL.x,PL.y,a.x,a.y));

  for(const z of alive){
    const dx=z.x-PL.x,dy=z.y-PL.y,pd=dist(0,0,dx,dy);
    if(pd<1)continue;
    const pa=Math.atan2(dy,dx)-PL.ang;
    let pa2=((pa%TAU)+TAU)%TAU;if(pa2>PI)pa2-=TAU;
    if(Math.abs(pa2)>HFOV+0.5)continue;

    const sx=((pa2+HFOV)/FOV)*W;
    const bi=clamp((pa2+HFOV)/FOV*NRAYS|0,0,NRAYS-1);
    if(ZB[bi]<pd-5)continue;

    const sh=clamp((H*CS*0.85)/Math.max(pd,1),10,H*3), sw=sh*0.48;
    const by_=HH-sh*0.5;
    const fog=clamp(pd/MAXD,0,1);
    const fl=z.hitFlash>0;
    const walkBob=Math.sin(z.bobT)*sw*0.06*(z.state==='chase'?1:0.4);

    ctx.globalAlpha=clamp(1-fog*0.6,0.08,1);
    ctx.save();

    // --- Legs ---
    const lstride=Math.sin(z.bobT*2)*sw*0.18;
    ctx.strokeStyle=fl?'#dd3010':`hsl(20,${30+z.hp/z.mhp*20}%,${12+z.hp/z.mhp*8}%)`;
    ctx.lineWidth=Math.max(1.5,sw*0.13);ctx.lineCap='round';
    // left
    ctx.beginPath();ctx.moveTo(sx-sw*0.1,by_+sh*0.75);ctx.lineTo(sx-sw*0.2+lstride,by_+sh*0.97+walkBob);ctx.stroke();
    // right
    ctx.beginPath();ctx.moveTo(sx+sw*0.1,by_+sh*0.75);ctx.lineTo(sx+sw*0.2-lstride,by_+sh*0.97-walkBob);ctx.stroke();

    // --- Body ---
    const bodyGrad=ctx.createLinearGradient(sx-sw*0.5,by_+sh*0.28,sx+sw*0.5,by_+sh*0.78);
    bodyGrad.addColorStop(0,fl?'#ee5030':`hsl(20,${25+z.hp/z.mhp*15}%,${18+z.hp/z.mhp*6}%)`);
    bodyGrad.addColorStop(0.5,fl?'#cc2010':`hsl(20,${20+z.hp/z.mhp*10}%,${12+z.hp/z.mhp*4}%)`);
    bodyGrad.addColorStop(1,fl?'#991008':'hsl(20,15%,8%)');
    ctx.fillStyle=bodyGrad;
    ctx.beginPath();
    ctx.ellipse(sx,by_+sh*0.58,sw*0.4,sh*0.28,0,0,TAU);ctx.fill();

    // Torn shirt detail
    ctx.fillStyle=fl?'rgba(200,50,30,0.3)':'rgba(0,0,0,0.2)';
    ctx.fillRect(sx-sw*0.25,by_+sh*0.38,sw*0.5,sh*0.04);
    ctx.fillRect(sx-sw*0.1,by_+sh*0.48,sw*0.25,sh*0.03);

    // --- Arms (reaching forward) ---
    const armSwing=Math.sin(z.bobT+1)*sw*0.2;
    const armCol=fl?'#cc3010':`hsl(20,${22+z.hp/z.mhp*12}%,${14+z.hp/z.mhp*5}%)`;
    ctx.strokeStyle=armCol;ctx.lineWidth=Math.max(1.5,sw*0.12);
    // left arm
    ctx.beginPath();ctx.moveTo(sx-sw*0.35,by_+sh*0.42);
    ctx.quadraticCurveTo(sx-sw*0.6,by_+sh*0.55,sx-sw*0.72-armSwing,by_+sh*0.58+armSwing*0.3);ctx.stroke();
    // right arm
    ctx.beginPath();ctx.moveTo(sx+sw*0.35,by_+sh*0.42);
    ctx.quadraticCurveTo(sx+sw*0.6,by_+sh*0.55,sx+sw*0.72+armSwing,by_+sh*0.58-armSwing*0.3);ctx.stroke();
    // clawed hands
    ctx.lineWidth=Math.max(1,sw*0.06);
    const hSize=sw*0.08;
    [[-sw*0.72-armSwing,sh*0.58+armSwing*0.3],[sw*0.72+armSwing,sh*0.58-armSwing*0.3]].forEach(([hx,hy])=>{
      for(let f=-1;f<=1;f++){
        ctx.beginPath();ctx.moveTo(sx+hx,by_+hy);ctx.lineTo(sx+hx+f*hSize,by_+hy+hSize*1.5);ctx.stroke();
      }
    });

    // --- Head ---
    const hr=sw*0.26, hx=sx, hy=by_+sh*0.19;
    // skull base
    const headGrad=ctx.createRadialGradient(hx-hr*0.2,hy-hr*0.2,hr*0.1,hx,hy,hr);
    headGrad.addColorStop(0,fl?'#dd4828':`hsl(18,${25+z.hp/z.mhp*15}%,${26+z.hp/z.mhp*8}%)`);
    headGrad.addColorStop(1,fl?'#992010':`hsl(18,20%,12%)`);
    ctx.fillStyle=headGrad;
    ctx.beginPath();ctx.arc(hx,hy,hr,0,TAU);ctx.fill();

    // Skull cracks/wounds
    if(!fl){
      ctx.strokeStyle='rgba(0,0,0,0.35)';ctx.lineWidth=hr*0.06;
      ctx.beginPath();ctx.moveTo(hx-hr*0.1,hy-hr*0.7);ctx.lineTo(hx+hr*0.05,hy-hr*0.1);ctx.stroke();
    }

    // Eyes (glowing red)
    const eo=hr*0.36;
    for(const ex of[hx-eo,hx+eo]){
      // glow
      ctx.shadowColor='#ff1100';ctx.shadowBlur=hr*0.6;
      ctx.fillStyle='#cc0000';
      ctx.beginPath();ctx.ellipse(ex,hy-hr*0.05,hr*0.18,hr*0.14,0,0,TAU);ctx.fill();
      ctx.shadowBlur=0;
      // pupil slit
      ctx.fillStyle='#000';
      ctx.beginPath();ctx.ellipse(ex,hy-hr*0.05,hr*0.06,hr*0.12,0,0,TAU);ctx.fill();
      // highlight
      ctx.fillStyle='rgba(255,80,60,0.6)';
      ctx.beginPath();ctx.arc(ex-hr*0.08,hy-hr*0.1,hr*0.05,0,TAU);ctx.fill();
    }

    // Mouth — rotting jaw
    ctx.strokeStyle=fl?'#ff2010':'#8a1a08';ctx.lineWidth=hr*0.1;ctx.lineCap='round';
    ctx.beginPath();
    ctx.moveTo(hx-hr*0.32,hy+hr*0.24);
    ctx.lineTo(hx-hr*0.14,hy+hr*0.38);
    ctx.lineTo(hx,hy+hr*0.28);
    ctx.lineTo(hx+hr*0.14,hy+hr*0.4);
    ctx.lineTo(hx+hr*0.32,hy+hr*0.26);ctx.stroke();
    // black void behind teeth
    ctx.fillStyle='rgba(0,0,0,0.7)';
    ctx.beginPath();ctx.ellipse(hx,hy+hr*0.3,hr*0.22,hr*0.1,0,0,TAU);ctx.fill();

    // --- HP bar ---
    if(z.hp<z.mhp&&pd<CS*9){
      const bw=sw*0.95,bh=Math.max(2.5,sh*0.025);
      const bx=sx-bw*0.5,bby_=by_-bh-5;
      ctx.fillStyle='rgba(0,0,0,0.72)';ctx.fillRect(bx,bby_,bw,bh);
      const hp=z.hp/z.mhp;
      ctx.fillStyle=hp>0.6?'#39ff14':hp>0.3?'#ffaa00':'#ff2200';
      ctx.fillRect(bx,bby_,bw*hp,bh);
      ctx.strokeStyle='rgba(255,255,255,0.1)';ctx.lineWidth=1;ctx.strokeRect(bx,bby_,bw,bh);
    }

    // --- Name tag (close) ---
    if(pd<CS*5){
      const a=clamp(1-pd/(CS*5),0,1);
      ctx.fillStyle=`rgba(255,80,50,${a*0.8})`;
      ctx.font=`${Math.max(8,sh*0.085)}px 'Share Tech Mono'`;
      ctx.textAlign='center';
      ctx.fillText(z.type.toUpperCase(),sx,by_-8);
    }

    ctx.restore();ctx.globalAlpha=1;ctx.shadowBlur=0;
  }
}

// ── Drops (ammo crates) ───────────────────────────────────
function drawDrops(W,H,HH){
  for(const d of drops){
    if(!d.alive)continue;
    d.bobT+=0.04;
    const dx=d.x-PL.x,dy=d.y-PL.y,pd=dist(0,0,dx,dy);
    if(pd<1)continue;
    const pa=Math.atan2(dy,dx)-PL.ang;
    let pa2=((pa%TAU)+TAU)%TAU;if(pa2>PI)pa2-=TAU;
    if(Math.abs(pa2)>HFOV+0.3)continue;
    const sx=((pa2+HFOV)/FOV)*W;
    const bi=clamp((pa2+HFOV)/FOV*NRAYS|0,0,NRAYS-1);
    if(ZB[bi]<pd-3)continue;
    const sh=clamp((H*CS*0.45)/Math.max(pd,1),8,90),sw=sh*0.8;
    const bob=Math.sin(d.bobT)*sh*0.05;
    const bx=sx-sw*0.5,by_=HH-sh*0.5+bob;
    const fog=clamp(pd/MAXD,0,1);
    ctx.globalAlpha=clamp(1-fog*0.55,0.15,1);

    // Box body
    ctx.fillStyle='#152a10';ctx.fillRect(bx,by_,sw,sh);
    // Cross stripe
    ctx.fillStyle='#1c3a16';ctx.fillRect(bx,by_+sh*0.4,sw,sh*0.2);
    ctx.fillRect(bx+sw*0.4,by_,sw*0.2,sh);
    // Glow border
    ctx.shadowColor='#39ff14';ctx.shadowBlur=sh*0.3;
    ctx.strokeStyle='#39ff14';ctx.lineWidth=1.2;ctx.strokeRect(bx,by_,sw,sh);
    ctx.shadowBlur=0;
    // Icon
    ctx.fillStyle='#39ff14';ctx.font=`bold ${Math.max(7,sh*0.42)}px monospace`;
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText('⊕',sx,by_+sh*0.5);
    ctx.textBaseline='alphabetic';
    // Label
    if(pd<CS*5){
      ctx.fillStyle=`rgba(57,255,20,${clamp(1-pd/(CS*5),0,1)*0.9})`;
      ctx.font=`${Math.max(6,sh*0.18)}px 'Share Tech Mono'`;
      ctx.fillText(`+${d.amt} AMMO`,sx,by_-4);
    }
    ctx.globalAlpha=1;ctx.textAlign='left';
  }
}

// ── Particles ─────────────────────────────────────────────
function drawParticles(W,H,HH){
  for(let i=parts.length-1;i>=0;i--){
    const p=parts[i];
    p.x+=p.vx;p.y+=p.vy;p.vx*=0.93;p.vy*=0.93;p.life--;
    if(p.life<=0){parts.splice(i,1);continue}
    const dx=p.x-PL.x,dy=p.y-PL.y,pd=dist(0,0,dx,dy);
    if(pd<1)continue;
    const pa=Math.atan2(dy,dx)-PL.ang;
    let pa2=((pa%TAU)+TAU)%TAU;if(pa2>PI)pa2-=TAU;
    if(Math.abs(pa2)>HFOV+0.3)continue;
    const sx=((pa2+HFOV)/FOV)*W;
    const bi=clamp((pa2+HFOV)/FOV*NRAYS|0,0,NRAYS-1);
    if(ZB[bi]<pd)continue;
    const sh=(H*CS*0.85)/Math.max(pd,1);
    const pr=Math.max(1,sh*0.035*p.life/p.ml);
    const fog=clamp(pd/MAXD,0,1);
    ctx.globalAlpha=p.life/p.ml*0.85*(1-fog*0.6);
    ctx.fillStyle=p.col;
    ctx.beginPath();ctx.arc(sx,HH+sh*0.5*(Math.random()*0.05-0.025),pr,0,TAU);ctx.fill();
    ctx.globalAlpha=1;
  }
}

// ── Weapon models ─────────────────────────────────────────
// Each gun has a distinct silhouette drawn in canvas 2D
function drawWeapon(W,H){
  const rc=PL.recoil,bob=PL.bob;
  const wy=H-180+rc*32+Math.abs(bob)*0.5;

  ctx.save();
  ctx.translate(W*0.5,wy);

  switch(PL.gun){
    case'pistol':  drawPistol(rc);break;
    case'shotgun': drawShotgun(rc);break;
    case'smg':     drawSMG(rc);break;
    case'ar':      drawAR(rc);break;
    case'sniper':  drawSniper(rc);break;
    case'minigun': drawMinigun(rc);break;
  }
  ctx.restore();
}

function mflash(rc,x,y,size){
  if(rc<0.4)return;
  ctx.save();
  ctx.shadowColor='rgba(255,200,80,.9)';ctx.shadowBlur=20;
  ctx.fillStyle=`rgba(255,215,90,${rc*0.85})`;
  for(let a=0;a<TAU;a+=PI/5){
    const r1=size+Math.random()*size*0.6,r2=(size*0.4)+Math.random()*size*0.3;
    ctx.beginPath();ctx.moveTo(x,y);
    ctx.lineTo(x+Math.cos(a)*r1,y+Math.sin(a)*r1);
    ctx.lineTo(x+Math.cos(a+PI/10)*r2,y+Math.sin(a+PI/10)*r2);
    ctx.closePath();ctx.fill();
  }
  ctx.fillStyle=`rgba(255,255,200,${rc*0.7})`;
  ctx.beginPath();ctx.arc(x,y,size*0.6+rc*3,0,TAU);ctx.fill();
  ctx.restore();
}

function drawPistol(rc){
  ctx.scale(1.5+rc*0.1,1.5+rc*0.1);
  // Shadow
  ctx.fillStyle='rgba(0,0,0,.4)';ctx.fillRect(-22,52,44,6);
  // Grip
  ctx.fillStyle='#1a140c';ctx.beginPath();ctx.roundRect(-12,20,18,48,3);ctx.fill();
  ctx.fillStyle='#26201a';ctx.fillRect(-10,22,8,44);
  // Mag
  ctx.fillStyle='#0e0c08';ctx.fillRect(-10,38,8,28);
  // Trigger guard
  ctx.strokeStyle='#201a12';ctx.lineWidth=2.5;ctx.lineCap='round';
  ctx.beginPath();ctx.arc(-4,32,10,0.2,PI*0.9);ctx.stroke();
  // Frame
  const fg=ctx.createLinearGradient(-50,-8,50,30);
  fg.addColorStop(0,'#3a3028');fg.addColorStop(1,'#181410');
  ctx.fillStyle=fg;ctx.beginPath();ctx.roundRect(-52,-10,104,38,4);ctx.fill();
  // Slide serrations
  ctx.strokeStyle='rgba(0,0,0,0.3)';ctx.lineWidth=1;
  for(let i=0;i<5;i++){ctx.beginPath();ctx.moveTo(30+i*4,-8);ctx.lineTo(30+i*4,25);ctx.stroke()}
  // Barrel
  ctx.fillStyle='#2a2420';ctx.fillRect(-5,-48,10,42);
  ctx.fillStyle='#0a0806';ctx.beginPath();ctx.arc(0,-48,3,PI,TAU);ctx.fill();
  // Sight
  ctx.fillStyle='#201c16';ctx.fillRect(-30,-14,60,6);
  ctx.fillStyle='#2c2820';ctx.fillRect(-2,-20,5,8);
  mflash(rc,0,-52,9);
}

function drawShotgun(rc){
  ctx.scale(1.52+rc*0.1,1.52+rc*0.1);
  ctx.fillStyle='rgba(0,0,0,.35)';ctx.fillRect(-100,58,200,7);
  // Stock (wood)
  const wg=ctx.createLinearGradient(70,-5,110,30);
  wg.addColorStop(0,'#6a4020');wg.addColorStop(1,'#3e2210');
  ctx.fillStyle=wg;ctx.beginPath();ctx.roundRect(78,-6,40,36,3);ctx.fill();
  ctx.strokeStyle='rgba(0,0,0,0.2)';ctx.lineWidth=1;
  for(let i=0;i<4;i++){ctx.beginPath();ctx.moveTo(82+i*7,-4);ctx.lineTo(82+i*7,28);ctx.stroke()}
  // Receiver
  const rg=ctx.createLinearGradient(-80,0,80,35);
  rg.addColorStop(0,'#404038');rg.addColorStop(1,'#181816');
  ctx.fillStyle=rg;ctx.beginPath();ctx.roundRect(-82,-12,168,48,5);ctx.fill();
  // Pump forend
  const pg=ctx.createLinearGradient(-50,20,50,40);
  pg.addColorStop(0,'#5a3818');pg.addColorStop(1,'#2e1c0a');
  ctx.fillStyle=pg;ctx.beginPath();ctx.roundRect(-50,26,100,18,3);ctx.fill();
  // Double barrel
  ctx.fillStyle='#2e2c28';ctx.fillRect(-7,-60,12,52);ctx.fillRect(5,-60,12,52);
  ctx.fillStyle='#0c0a08';ctx.beginPath();ctx.arc(-3,-60,3,PI,TAU);ctx.fill();
  ctx.beginPath();ctx.arc(9,-60,3,PI,TAU);ctx.fill();
  // Guard
  ctx.strokeStyle='#2a2820';ctx.lineWidth=3;
  ctx.beginPath();ctx.arc(-8,36,14,0.1,PI*0.9);ctx.stroke();
  // Grip
  ctx.fillStyle='#5a3818';ctx.beginPath();ctx.roundRect(-16,22,20,42,3);ctx.fill();
  // Sight
  ctx.fillStyle='#242220';ctx.fillRect(-45,-16,90,8);
  mflash(rc,-1,-62,14);mflash(rc,11,-62,14);
}

function drawSMG(rc){
  ctx.scale(1.48+rc*0.1,1.48+rc*0.1);
  ctx.fillStyle='rgba(0,0,0,.35)';ctx.fillRect(-80,56,160,6);
  // Folded stock
  ctx.fillStyle='#222018';ctx.beginPath();ctx.roundRect(72,-8,28,34,3);ctx.fill();
  ctx.strokeStyle='#2e2c22';ctx.lineWidth=2;
