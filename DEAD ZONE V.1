<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>DEAD ZONE</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Share+Tech+Mono&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
:root{--g:#39ff14;--r:#cc0000;--gold:#f5c518;--glow:0 0 14px rgba(57,255,20,.48);--rglow:0 0 14px rgba(204,0,0,.55)}
body{background:#000;overflow:hidden;width:100vw;height:100vh;font-family:'Share Tech Mono',monospace;color:#d4c5a9;cursor:none;user-select:none}
#c{display:block;position:absolute;inset:0;width:100%;height:100%}
#mm{position:absolute;top:16px;left:16px;width:128px;height:128px;border:1px solid rgba(57,255,20,.2);background:rgba(0,0,0,.75);border-radius:3px;z-index:4;image-rendering:pixelated}

/* HUD */
#hud{position:absolute;inset:0;pointer-events:none;z-index:5}
#hud.off{display:none}
#topbar{position:absolute;top:0;left:0;right:0;height:54px;background:linear-gradient(180deg,rgba(0,0,0,.7) 0%,transparent 100%);display:flex;align-items:center;justify-content:center;gap:56px;padding-top:4px}
.hs{display:flex;flex-direction:column;align-items:center;gap:2px}
.hsv{font-family:'Bebas Neue',sans-serif;font-size:26px;color:#fff;letter-spacing:.06em;line-height:1;text-shadow:0 0 20px rgba(255,255,255,.15)}
.hsl{font-size:8px;letter-spacing:.32em;color:rgba(212,197,169,.38);text-transform:uppercase}

/* bottom-left: health */
#hlth{position:absolute;bottom:28px;left:28px}
.hlab{font-size:9px;letter-spacing:.3em;color:rgba(212,197,169,.4);margin-bottom:4px}
#hptrack{width:192px;height:8px;background:rgba(0,0,0,.6);border:1px solid rgba(255,255,255,.1);border-radius:2px;overflow:hidden}
#hpf{height:100%;width:100%;background:linear-gradient(90deg,#8b0000,#dd2200);transition:width .12s;border-radius:2px;box-shadow:0 0 8px rgba(220,50,0,.4)}
#hpn{font-size:10px;margin-top:3px;letter-spacing:.08em;color:#d4c5a9}

/* bottom-right: ammo */
#amhud{position:absolute;bottom:28px;right:28px;text-align:right}
#wname{font-size:9px;letter-spacing:.28em;color:rgba(212,197,169,.38);margin-bottom:3px}
#amnum{font-family:'Bebas Neue',sans-serif;font-size:62px;line-height:1;color:#fff;letter-spacing:.05em}
#amnum .slash{font-size:28px;opacity:.3;margin:0 2px}
#amres{font-size:10px;color:rgba(212,197,169,.35);letter-spacing:.14em;margin-top:1px}
#rldwrap{margin-top:5px;display:none;text-align:right}
#rldtrack{width:130px;height:3px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden;margin-left:auto}
#rldfill{height:100%;width:0%;background:var(--g);box-shadow:var(--glow);border-radius:2px}
#rldtxt{font-size:8px;color:var(--g);letter-spacing:.26em;margin-top:3px;text-shadow:var(--glow)}

/* crosshair */
#xh{position:absolute;top:50%;left:50%;width:28px;height:28px;transform:translate(-50%,-50%)}
#xh::before,#xh::after{content:'';position:absolute;background:rgba(255,255,255,.85);box-shadow:0 0 4px rgba(0,0,0,.8)}
#xh::before{width:2px;height:28px;left:13px;top:0}
#xh::after{width:28px;height:2px;left:0;top:13px}
#xhc{position:absolute;top:50%;left:50%;width:3px;height:3px;background:#fff;border-radius:50%;transform:translate(-50%,-50%)}
#xh.hit::before,#xh.hit::after{background:#ff2222;box-shadow:0 0 8px #f00}

/* hit marker */
#hitmark{position:absolute;top:50%;left:50%;width:38px;height:38px;transform:translate(-50%,-50%);opacity:0}
#hitmark::before,#hitmark::after{content:'';position:absolute;background:#ff3333;box-shadow:0 0 6px #f00}
#hitmark::before{width:2px;height:14px;left:18px;top:0}
#hitmark::after{width:14px;height:2px;top:18px;left:0}
#hitmark.pop{animation:hitpop .22s forwards}
@keyframes hitpop{0%{opacity:1;transform:translate(-50%,-50%) scale(1.5)}100%{opacity:0;transform:translate(-50%,-50%) scale(.7)}}

/* damage vignette */
#dmgv{position:absolute;inset:0;background:radial-gradient(ellipse,transparent 35%,rgba(150,0,0,.9) 100%);opacity:0;pointer-events:none;transition:opacity .06s}

/* killfeed */
#kfeed{position:absolute;top:72px;right:16px;display:flex;flex-direction:column;gap:4px;align-items:flex-end}
.krow{font-size:10px;color:#ff5555;background:rgba(0,0,0,.55);padding:3px 10px;border-left:2px solid #aa0000;letter-spacing:.1em;animation:kfade 3s forwards}
.krow.green{color:var(--g);border-color:rgba(57,255,20,.6)}
@keyframes kfade{0%{opacity:1;transform:translateX(5px)}75%{opacity:1}100%{opacity:0}}

/* wave banner */
#wbanner{position:absolute;top:34%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;opacity:0}
#wbanner.show{animation:wban 3.4s forwards}
@keyframes wban{0%{opacity:0;transform:translate(-50%,-50%) scale(.8)}10%{opacity:1;transform:translate(-50%,-50%) scale(1.05)}70%{opacity:1}100%{opacity:0}}
#wbtitle{font-family:'Bebas Neue',sans-serif;font-size:clamp(46px,8vw,82px);color:#fff;letter-spacing:.1em;text-shadow:0 0 50px #cc0000,0 0 20px #cc0000}
#wbsub{font-size:11px;letter-spacing:.36em;color:var(--g);text-shadow:var(--glow);margin-top:5px}
#wbloc{font-size:9px;letter-spacing:.28em;color:rgba(212,197,169,.45);margin-top:3px}

/* fps */
#fpsc{position:absolute;top:16px;right:16px;font-size:9px;color:rgba(57,255,20,.28);letter-spacing:.1em}

/* controls hint */
#ctrls{position:absolute;bottom:14px;left:50%;transform:translateX(-50%);display:flex;gap:22px;font-size:8px;color:rgba(212,197,169,.2);letter-spacing:.14em;white-space:nowrap}

/* low health glow */
@keyframes lpulse{0%,100%{box-shadow:inset 0 0 100px rgba(180,0,0,0)}50%{box-shadow:inset 0 0 100px rgba(180,0,0,.45)}}
body.lhp{animation:lpulse .7s ease-in-out infinite}

/* ammo drop icon near crosshair */
#pickupflash{position:absolute;top:56%;left:50%;transform:translateX(-50%);font-size:10px;letter-spacing:.22em;color:var(--g);text-shadow:var(--glow);opacity:0;pointer-events:none}
#pickupflash.show{animation:pfade 1.8s forwards}
@keyframes pfade{0%{opacity:1;transform:translateX(-50%) translateY(0)}100%{opacity:0;transform:translateX(-50%) translateY(-20px)}}

/* ───────────────── SCREENS ───────────────── */
.sc{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:20;pointer-events:auto;transition:opacity .3s}
.sc.off{opacity:0;pointer-events:none}

/* title */
#st{background:radial-gradient(ellipse at 50% 60%,#0e0006 0%,#000 65%)}
#st::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.14) 3px,rgba(0,0,0,.14) 4px);pointer-events:none}
.logo{font-family:'Bebas Neue',sans-serif;font-size:clamp(70px,14vw,130px);line-height:.88;letter-spacing:.07em;color:#fff;text-align:center;text-shadow:0 0 60px #c00,0 0 120px #600,6px 6px 0 #7a0000;animation:logopulse 3s ease-in-out infinite}
@keyframes logopulse{0%,100%{text-shadow:0 0 60px #c00,0 0 120px #600,6px 6px 0 #7a0000}50%{text-shadow:0 0 80px #f22,0 0 160px #800,6px 6px 0 #7a0000}}
.lsub{font-size:10px;letter-spacing:.48em;color:var(--g);text-shadow:var(--glow);margin:10px 0 56px}
.btn{font-family:'Share Tech Mono',monospace;font-size:14px;letter-spacing:.24em;padding:13px 52px;background:transparent;border:1px solid var(--g);color:var(--g);cursor:pointer;text-transform:uppercase;margin:5px;text-shadow:var(--glow);box-shadow:var(--glow),inset 0 0 20px rgba(57,255,20,.04);transition:all .16s;pointer-events:auto}
.btn:hover{background:rgba(57,255,20,.1);box-shadow:0 0 28px rgba(57,255,20,.6),inset 0 0 20px rgba(57,255,20,.08);transform:scaleX(1.03)}
.btn.red{border-color:var(--r);color:var(--r);text-shadow:var(--rglow);box-shadow:var(--rglow)}
.btn.red:hover{background:rgba(204,0,0,.1);box-shadow:0 0 28px rgba(204,0,0,.6)}
.screentitle{font-family:'Bebas Neue',sans-serif;font-size:clamp(44px,7vw,72px);letter-spacing:.08em;margin-bottom:18px}

/* pause / gameover */
#spause,#sover,#sshop{background:rgba(0,0,0,.92);backdrop-filter:blur(6px)}
.bigtitle{font-family:'Bebas Neue',sans-serif;font-size:clamp(54px,10vw,96px);letter-spacing:.08em}
.red-t{color:#cc0000;text-shadow:0 0 60px #880000}
.whi-t{color:#fff}
.grn-t{color:var(--g);text-shadow:var(--glow)}
.statgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px 44px;margin:18px 0 32px;font-size:12px;letter-spacing:.1em}
.srow{display:flex;justify-content:space-between;gap:14px}
.slbl{color:rgba(212,197,169,.4)}
.sval{color:var(--g);text-shadow:var(--glow)}

/* shop */
#sshop{flex-direction:column;padding:32px 16px 24px;overflow-y:auto;gap:0}
#shoptimerbox{width:min(640px,90vw);margin-bottom:22px}
#shoptimerhead{display:flex;justify-content:space-between;font-size:9px;letter-spacing:.22em;color:rgba(212,197,169,.4);margin-bottom:5px}
#shoptimerhead span{color:var(--gold);font-size:10px}
#shoptrack{height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden}
#shopbar{height:100%;width:100%;background:linear-gradient(90deg,#cc0000,#ff7700,var(--gold));box-shadow:0 0 8px rgba(245,197,24,.35);border-radius:3px;transition:width .09s linear}
#shoptitle{font-family:'Bebas Neue',sans-serif;font-size:clamp(32px,5.5vw,58px);letter-spacing:.1em;color:var(--gold);text-shadow:0 0 26px rgba(245,197,24,.45);margin-bottom:3px}
#shopsub{font-size:9px;letter-spacing:.34em;color:rgba(212,197,169,.3);margin-bottom:16px}
#shopcoindisp{font-size:13px;letter-spacing:.16em;color:var(--gold);margin-bottom:16px;text-shadow:0 0 8px rgba(245,197,24,.3)}
#shopgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(152px,1fr));gap:10px;width:min(700px,92vw)}
.sitem{background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.08);border-radius:5px;padding:14px 12px;cursor:pointer;transition:all .15s;pointer-events:auto}
.sitem:hover:not(.owned):not(.cant){background:rgba(57,255,20,.06);border-color:rgba(57,255,20,.35);transform:translateY(-2px)}
.sitem.owned{border-color:rgba(57,255,20,.28);background:rgba(57,255,20,.045);cursor:default}
.sitem.equipped{border-color:var(--gold)!important;background:rgba(245,197,24,.06)!important}
.sitem.cant{opacity:.35;cursor:not-allowed}
.iname{font-family:'Bebas Neue',sans-serif;font-size:19px;letter-spacing:.06em;color:#fff;margin-bottom:3px}
.idesc{font-size:8px;letter-spacing:.1em;color:rgba(212,197,169,.35);margin-bottom:7px;line-height:1.5}
.istats{font-size:8px;letter-spacing:.08em;color:rgba(57,255,20,.6);margin-bottom:8px;line-height:1.9}
.iprice{font-size:11px;letter-spacing:.14em;color:var(--gold)}
.iowned{font-size:8px;letter-spacing:.18em;color:var(--g);text-shadow:var(--glow)}
.iequip{font-size:8px;letter-spacing:.18em;color:var(--gold)}

/* scanlines */
#scanl{position:fixed;inset:0;pointer-events:none;z-index:99;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.032) 2px,rgba(0,0,0,.032) 4px)}
</style>
</head>
<body>
<canvas id="c"></canvas>
<canvas id="mm" width="128" height="128"></canvas>

<!-- HUD -->
<div id="hud" class="off">
  <div id="dmgv"></div>
  <div id="topbar">
    <div class="hs"><span class="hsv" id="hudwave">1</span><span class="hsl">Wave</span></div>
    <div class="hs"><span class="hsv" id="hudkills">0</span><span class="hsl">Kills</span></div>
    <div class="hs"><span class="hsv" id="hudscore">0</span><span class="hsl">Score</span></div>
    <div class="hs"><span class="hsv" id="hudcoins" style="color:var(--gold)">0</span><span class="hsl">Coins</span></div>
  </div>
  <div id="xh"><div id="xhc"></div></div>
  <div id="hitmark"></div>
  <div id="hlth">
    <div class="hlab">HEALTH</div>
    <div id="hptrack"><div id="hpf"></div></div>
    <div id="hpn">100 / 100</div>
  </div>
  <div id="amhud">
    <div id="wname">PISTOL</div>
    <div id="amnum"><span id="amcur">12</span><span class="slash"> / </span><span id="ammax">12</span></div>
    <div id="amres">RESERVE: <span id="amresval">48</span></div>
    <div id="rldwrap">
      <div id="rldtrack"><div id="rldfill"></div></div>
      <div id="rldtxt">RELOADING</div>
    </div>
  </div>
  <div id="kfeed"></div>
  <div id="wbanner"><div id="wbtitle">WAVE 1</div><div id="wbsub">SURVIVE</div><div id="wbloc"></div></div>
  <div id="pickupflash"></div>
  <div id="fpsc">60 FPS</div>
  <div id="ctrls"><span>WASD MOVE</span><span>MOUSE AIM</span><span>LMB SHOOT</span><span>R RELOAD</span><span>SHIFT SPRINT</span><span>ESC PAUSE</span></div>
</div>

<!-- TITLE -->
<div id="st" class="sc">
  <div class="logo">DEAD<br>ZONE</div>
  <div class="lsub">FPS ZOMBIE SURVIVAL</div>
  <button class="btn" id="b_start">▶ &nbsp;START GAME</button>
  <button class="btn" id="b_how">? &nbsp;HOW TO PLAY</button>
  <div style="margin-top:22px;font-size:9px;color:rgba(212,197,169,.2);letter-spacing:.22em">CLICK TO LOCK MOUSE · ESC PAUSE</div>
</div>

<!-- HOW TO PLAY -->
<div id="show" class="sc off">
  <div class="screentitle whi-t">HOW TO PLAY</div>
  <div style="font-size:13px;letter-spacing:.12em;line-height:2.5;text-align:left">
    <div><span style="color:var(--g)">WASD</span> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Move</div>
    <div><span style="color:var(--g)">MOUSE</span> &nbsp;&nbsp;&nbsp;&nbsp;Look · 360° + Up/Down</div>
    <div><span style="color:var(--g)">LMB / SPACE</span> &nbsp;Shoot</div>
    <div><span style="color:var(--g)">R</span> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Reload</div>
    <div><span style="color:var(--g)">SHIFT</span> &nbsp;&nbsp;&nbsp;&nbsp;Sprint</div>
    <div><span style="color:var(--g)">ESC</span> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Pause</div>
  </div>
  <br>
  <div style="font-size:9px;color:rgba(212,197,169,.28);letter-spacing:.12em;line-height:2.2;text-align:center">
    Kill zombies to earn coins.<br>A 15s shop opens after each wave.<br>Zombies drop ammo (5% chance).<br>Maps rotate every 4 waves. Endless.
  </div>
  <br><button class="btn" id="b_backhow">← BACK</button>
</div>

<!-- PAUSE -->
<div id="spause" class="sc off">
  <div class="bigtitle whi-t">PAUSED</div><br>
  <button class="btn" id="b_resume">▶ RESUME</button>
  <button class="btn red" id="b_quitmenu">✕ MAIN MENU</button>
</div>

<!-- SHOP -->
<div id="sshop" class="sc off">
  <div id="shoptimerbox">
    <div id="shoptimerhead"><span>ARMORY CLOSES IN</span><span id="shopsec">15s</span></div>
    <div id="shoptrack"><div id="shopbar"></div></div>
  </div>
  <div id="shoptitle">ARMORY</div>
  <div id="shopsub">SPEND YOUR COINS BEFORE NEXT WAVE</div>
  <div id="shopcoindisp">⬡ <span id="shopcval">0</span> COINS</div>
  <div id="shopgrid"></div>
  <button class="btn" id="b_skip" style="margin-top:18px">SKIP →</button>
</div>

<!-- GAME OVER -->
<div id="sover" class="sc off">
  <div class="bigtitle red-t">YOU DIED</div>
  <div class="statgrid" id="overstats"></div>
  <button class="btn" id="b_retry">↺ TRY AGAIN</button>
  <button class="btn red" id="b_quitover">✕ MAIN MENU</button>
</div>

<div id="scanl"></div>

<script>
"use strict";
// ════════════════════════════════════════════════════════
//  DEAD ZONE v3 — Complete Rewrite
//  Clean audio · Fixed AI · Better rendering · Endless waves
// ════════════════════════════════════════════════════════

// ── Canvas ───────────────────────────────────────────────
const C=document.getElementById('c'),ctx=C.getContext('2d');
const MM=document.getElementById('mm'),mmc=MM.getContext('2d');
function rsz(){C.width=innerWidth;C.height=innerHeight}
rsz();addEventListener('resize',rsz);

// ── Math ─────────────────────────────────────────────────
const PI=Math.PI,TAU=PI*2,HALF_PI=PI/2;
const clamp=(v,lo,hi)=>v<lo?lo:v>hi?hi:v;
const lerp=(a,b,t)=>a+(b-a)*t;
const dist=(ax,ay,bx,by)=>Math.sqrt((ax-bx)**2+(ay-by)**2);
const angleDiff=(a,b)=>{let d=((a-b)%TAU+TAU)%TAU;return d>PI?d-TAU:d};

// ── Audio (clean synthesized sounds) ─────────────────────
let AC=null;
function initAC(){if(!AC)AC=new(window.AudioContext||window.webkitAudioContext)()}

// Master compressor so nothing clips
let masterGain,compressor;
function getChain(){
  if(!AC)return null;
  if(!masterGain){
    masterGain=AC.createGain();masterGain.gain.value=0.85;
    compressor=AC.createDynamicsCompressor();
    compressor.threshold.value=-12;compressor.knee.value=6;
    compressor.ratio.value=4;compressor.attack.value=0.003;compressor.release.value=0.15;
    masterGain.connect(compressor);compressor.connect(AC.destination);
  }
  return masterGain;
}

function playNoise(opts){
  const{dur=0.1,vol=0.3,atk=0.002,rel=0.08,ftype='lowpass',ffreq=1200,fq=1,pitch=0}=opts;
  if(!AC)return;const chain=getChain();
  const n=Math.ceil(AC.sampleRate*(dur+rel+0.05));
  const buf=AC.createBuffer(1,n,AC.sampleRate);
  const d=buf.getChannelData(0);
  // colored noise by simple filtering in buffer
  let last=0;
  for(let i=0;i<n;i++){const w=Math.random()*2-1;last=last*0.5+w*0.5;d[i]=last}
  const s=AC.createBufferSource(),g=AC.createGain(),f=AC.createBiquadFilter();
  f.type=ftype;f.frequency.value=ffreq;f.Q.value=fq;
  s.buffer=buf;s.detune.value=pitch;
  s.connect(f);f.connect(g);g.connect(chain);
  const t=AC.currentTime;
  g.gain.setValueAtTime(0,t);
  g.gain.linearRampToValueAtTime(vol,t+atk);
  g.gain.exponentialRampToValueAtTime(0.0001,t+dur+rel);
  s.start(t);s.stop(t+dur+rel+0.06);
}

function playTone(opts){
  const{freq=440,freq2=null,type='sine',dur=0.15,vol=0.3,atk=0.005,dec=0.05,sus=0.6,rel=0.1,det=0,filter=null,ffreq=2000}=opts;
  if(!AC)return;const chain=getChain();
  const o=AC.createOscillator(),g=AC.createGain();
  let last=g;
  if(filter){const f=AC.createBiquadFilter();f.type=filter;f.frequency.value=ffreq;g.connect(f);f.connect(chain)}
  else g.connect(chain);
  o.connect(g);
  o.type=type;o.detune.value=det;
  const t=AC.currentTime;
  o.frequency.setValueAtTime(freq,t);
  if(freq2)o.frequency.exponentialRampToValueAtTime(freq2,t+dur);
  g.gain.setValueAtTime(0,t);
  g.gain.linearRampToValueAtTime(vol,t+atk);
  g.gain.setValueAtTime(vol*sus,t+atk+dec);
  g.gain.exponentialRampToValueAtTime(0.0001,t+dur+rel);
  o.start(t);o.stop(t+dur+rel+0.06);
}

const SFX={
  // Gunshots — layered noise + body tone per weapon type
  pistol(){
    playNoise({dur:.028,vol:.55,atk:.001,rel:.06,ftype:'bandpass',ffreq:2200,fq:0.8});
    playTone({freq:180,freq2:60,type:'sawtooth',dur:.06,vol:.25,atk:.001,dec:.02,sus:.2,rel:.08,filter:'lowpass',ffreq:400});
  },
  shotgun(){
    playNoise({dur:.055,vol:.9,atk:.001,rel:.18,ftype:'lowpass',ffreq:1400,fq:0.4});
    playTone({freq:90,freq2:30,type:'sawtooth',dur:.09,vol:.4,atk:.001,dec:.03,sus:.25,rel:.12,filter:'lowpass',ffreq:280});
    // rattle
    setTimeout(()=>playNoise({dur:.02,vol:.25,atk:.001,rel:.04,ftype:'highpass',ffreq:4000}),55);
  },
  smg(){
    playNoise({dur:.018,vol:.35,atk:.001,rel:.04,ftype:'bandpass',ffreq:2800,fq:1.2});
    playTone({freq:220,freq2:90,type:'square',dur:.03,vol:.15,atk:.001,dec:.01,sus:.15,rel:.04,filter:'lowpass',ffreq:500});
  },
  ar(){
    playNoise({dur:.032,vol:.55,atk:.001,rel:.07,ftype:'bandpass',ffreq:1900,fq:0.9});
    playTone({freq:160,freq2:55,type:'sawtooth',dur:.055,vol:.28,atk:.001,dec:.02,sus:.22,rel:.09,filter:'lowpass',ffreq:350});
  },
  sniper(){
    playNoise({dur:.04,vol:.8,atk:.001,rel:.35,ftype:'bandpass',ffreq:1200,fq:0.5});
    playTone({freq:120,freq2:25,type:'sawtooth',dur:.12,vol:.5,atk:.001,dec:.04,sus:.3,rel:.28,filter:'lowpass',ffreq:220});
